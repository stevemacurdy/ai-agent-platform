+        <td className="py-3 px-4 text-gray-700 whitespace-nowrap">{formatDateShort(record.date)}</td>
+        <td className="py-3 px-4 font-medium text-gray-900">{record.vendor}</td>
+        <td className="py-3 px-4 text-gray-600">
