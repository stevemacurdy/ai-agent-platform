+'use client';
+
+import { useState } from 'react';
+import Link from 'next/link';
+import { usePathname } from 'next/navigation';
+
+const NAV_ITEMS = [
+  { label: 'Dashboard', href: '', icon: 'home' },
+  { label: 'Inventory', href: '/inventory', icon: 'box' },
