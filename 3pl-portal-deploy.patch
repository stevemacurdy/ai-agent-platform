+      paid_date: isCurrent ? undefined : m.due,
+      status: isCurrent ? 'posted' : 'paid',
+      days_late: isCurrent ? 0 : tp.daysLate,
+      created_at: m.start + 'T00:00:00Z',
+      updated_at: m.end + 'T00:00:00Z',
+    });
+  }
+  return invoices;
+}
